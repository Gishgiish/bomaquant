# Development defaults (safe for local testing)
APP_ENV=development
AUTH_ENABLED=false
API_USERNAME=admin
API_PASSWORD=change-me
NSE_RAPIDAPI_KEY=test_key_12345678901234567890
NSE_API_TIMEOUT=10
NSE_MAX_RETRIES=3
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300

# Production overrides (set these in deployment secrets/config)
# APP_ENV=production
# AUTH_ENABLED=true
# API_USERNAME=change-me
# API_PASSWORD=change-me
# NSE_RAPIDAPI_KEY=replace-with-real-key
# NSE_API_TIMEOUT=15
# NSE_MAX_RETRIES=5
# CACHE_ENABLED=true
# CACHE_TTL_SECONDS=900
